# Aegis-Pay Configuration Example
# Copy this file to .env and update the values

# Gateway Configuration
PORT=8080
ENV=development

# Infrastructure
REDIS_ADDR=localhost:6379
POSTGRES_URL=postgres://aegis_user:aegis_password@localhost:5432/aegis_db?sslmode=disable
KAFKA_BROKERS=localhost:19092

# AI / Recovery
ANTHROPIC_API_KEY=your_key_here
